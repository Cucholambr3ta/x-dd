{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Cucholambr3ta/x-dd/raw/main/schemas/install-profiles.schema.json",
  "title": "X-DD Install Profiles Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "profiles"],
  "properties": {
    "$schema": {"type": "string"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "description": {"type": "string"},
    "profiles": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/profile"}
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "modules"],
      "properties": {
        "description": {"type": "string"},
        "modules": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        },
        "requires_wrapper_global": {"type": "boolean"},
        "max_size_mb": {"type": "number"}
      }
    }
  }
}

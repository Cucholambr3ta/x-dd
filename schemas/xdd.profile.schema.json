{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Cucholambr3ta/x-dd/raw/main/schemas/xdd.profile.schema.json",
  "title": "X-DD Project Profile",
  "description": "Declarativo: qué es el proyecto + opcionalmente branding (Sprint 13).",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "profile": {
      "type": "string",
      "enum": ["saas", "mobile", "lib", "internal", "custom"]
    },
    "capabilities": {"type": "object", "additionalProperties": {"type": "boolean"}},
    "stacks": {"type": "object"},
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "description": "Workspace mode (Sprint 14 + ADR-0012). Permite que X-DD opere sobre un workspace con N proyectos.",
      "properties": {
        "enabled": {"type": "boolean", "default": false},
        "root": {"type": "string", "description": "Ruta absoluta o relativa al workspace root"},
        "projects": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "path"],
            "properties": {
              "name": {"type": "string", "pattern": "^[a-z][a-z0-9-]+$"},
              "path": {"type": "string"},
              "profile": {"type": "string", "enum": ["minimal", "core", "developer", "security", "research", "full"]}
            }
          }
        },
        "shared_memory": {"type": "boolean", "default": true, "description": "Comparte ~/.xdd/state.db entre proyectos del workspace"},
        "shared_gate_key": {"type": "boolean", "default": false, "description": "Comparte .gate-key entre proyectos (security warning)"}
      }
    },
    "branding": {
      "type": "object",
      "additionalProperties": false,
      "description": "White-labeling (Sprint 13 + ADR-0011). Default sin sección = X-DD identity.",
      "properties": {
        "ecosystem_name": {"type": "string", "default": "X-DD", "minLength": 1, "maxLength": 64},
        "ecosystem_slug": {"type": "string", "default": "xdd", "pattern": "^[a-z][a-z0-9-]+$"},
        "orchestrator_trigger": {"type": "string", "default": "xdd", "pattern": "^[a-z][a-z0-9-]+$"},
        "rename_subworkflows": {"type": "boolean", "default": false},
        "orchestrator_persona": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "tone": {"type": "string", "enum": ["technical", "friendly", "casual", "formal", "custom"]},
            "custom_prompt": {"type": ["string", "null"]}
          }
        },
        "output": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "compact": {"type": "string", "enum": ["off", "lite", "standard", "ultra"]}
          }
        },
        "attribution_required": {"type": "boolean", "default": true}
      }
    }
  }
}

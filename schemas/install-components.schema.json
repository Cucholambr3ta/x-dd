{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Cucholambr3ta/x-dd/raw/main/schemas/install-components.schema.json",
  "title": "X-DD Install Components Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "components"],
  "properties": {
    "$schema": {"type": "string"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "description": {"type": "string"},
    "components": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/component"}
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["module", "files"],
      "properties": {
        "module": {"type": "string"},
        "files": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        }
      }
    }
  }
}

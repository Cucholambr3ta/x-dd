{
  "$schema": "../schemas/install-modules.schema.json",
  "version": "0.1.0",
  "description": "M\u00f3dulos instalables de X-DD. Cada m\u00f3dulo agrupa archivos coherentes para una capacidad espec\u00edfica.",
  "modules": {
    "core": {
      "description": "N\u00facleo: scripts (doctor, init, start, adapt), templates, CLAUDE.md, MEJORAS, configs base.",
      "files": [
        "CLAUDE.md",
        "MEJORAS-X-DD.md",
        "DEPENDENCIES.md",
        "Makefile",
        ".editorconfig",
        ".gitattributes",
        "scripts/xdd-doctor.sh",
        "scripts/xdd-init.sh",
        "scripts/xdd-start.sh",
        "scripts/xdd-adapt.sh",
        "scripts/lint-workflows.sh",
        "scripts/hooks/post-commit",
        "templates/",
        "docs/constitucion.md",
        "AGENTS.md"
      ],
      "required": true
    },
    "workflows-core": {
      "description": "Cat\u00e1logo de 49 workflows X-DD (.agent/workflows/).",
      "files": [
        ".agent/workflows/",
        "prompts/workflows/"
      ],
      "required": true
    },
    "agents-core": {
      "description": "Registry tipado de 180 agentes especializados.",
      "files": [
        "prompts/agents/registry.json",
        "prompts/agents/registry.schema.json",
        "prompts/agents/",
        "scripts/validate-registry.py",
        "scripts/generate-equipo.sh",
        "scripts/migrate-agents-to-registry.py"
      ],
      "required": false
    },
    "hooks-runtime": {
      "description": "Hook system event-driven (PreToolUse, PostToolUse, SessionStart, Stop). 8 hooks bash.",
      "files": [
        ".agent/hooks/",
        "schemas/hooks.schema.json"
      ],
      "required": false,
      "requires": [
        "core"
      ]
    },
    "mcp-server": {
      "description": "MCP server propio de X-DD (Python stdlib pura, 6 tools).",
      "files": [
        "xdd-mcp-server/",
        "docs/MCP_INTEGRATION.md"
      ],
      "required": false,
      "requires": [
        "core",
        "agents-core"
      ]
    },
    "gate-keeper": {
      "description": "Gate keeper program\u00e1tico con HMAC-SHA256.",
      "files": [
        "scripts/xdd-gate.py",
        "docs/GATE.md"
      ],
      "required": false,
      "requires": [
        "core"
      ]
    },
    "platform-configs": {
      "description": "Configs por IDE (.claude/, .opencode/, MCP configs).",
      "files": [
        ".claude/settings.json"
      ],
      "required": false
    },
    "ci-runtime": {
      "description": "GitHub Actions workflows + pre-commit + Renovate.",
      "files": [
        ".github/workflows/",
        ".github/renovate.json",
        ".pre-commit-config.yaml",
        ".markdownlint.yaml"
      ],
      "required": false
    },
    "memory": {
      "description": "Plantillas de memoria viva (memoria.md, lecciones.md).",
      "files": [
        "templates/memoria.template.md",
        "templates/lecciones.template.md"
      ],
      "required": false
    },
    "eval-harness": {
      "description": "Eval-harness con grader types (Sprint 10).",
      "files": [
        "scripts/xdd-eval.py",
        "evals/"
      ],
      "required": false,
      "available_from": "0.1.0-sprint10"
    },
    "continuous-learning": {
      "description": "Continuous learning con instincts + /evolve (Sprint 9).",
      "files": [
        "scripts/xdd-state.py",
        ".xdd/state.db"
      ],
      "required": false,
      "available_from": "0.1.0-sprint9"
    },
    "orchestration": {
      "description": "Multi-agent orchestration runtime /orchestrate (Sprint 11).",
      "files": [
        "scripts/xdd-orchestrate.py"
      ],
      "required": false,
      "available_from": "0.1.0-sprint11"
    },
    "agent-shield": {
      "description": "AgentShield: security audit est\u00e1tica del framework (Sprint 12).",
      "files": [
        "scripts/xdd-shield.py",
        "docs/AGENT_SHIELD.md"
      ],
      "required": false,
      "available_from": "0.1.0-sprint12"
    },
    "docs-governance": {
      "description": "Documentaci\u00f3n governance + guides core que CLAUDE.md/AGENTS.md referencian (constitucion, integration, retrofit, hooks, config, install).",
      "files": [
        "docs/constitucion.md",
        "docs/X-DD_Integration_Guide.md",
        "docs/RETROFIT_GUIDE.md",
        "docs/HOOKS.md",
        "docs/CONFIG.md",
        "docs/INSTALL_PROFILES.md",
        "INSTALL.md",
        "AGENTS.md"
      ]
    },
    "personas": {
      "description": "White-labeling (Sprint 13): xdd-brand + 4 personas presets.",
      "files": [
        "scripts/xdd-brand.sh",
        "prompts/orchestrator/"
      ]
    },
    "skills-core": {
      "description": "Skills system (Sprint 10-21): registry + 6 skills propias + xdd-bundle.",
      "files": [
        "skills/",
        "prompts/skills/",
        "scripts/xdd-bundle.py"
      ]
    },
    "mcp-server-global": {
      "description": "Sprint 25 + ADR-0035: wrapper installer global ~/.local/bin/xdd-mcp-server.",
      "files": [
        "scripts/xdd-mcp-install-global.sh"
      ]
    },
    "workspace-monorepo": {
      "description": "Sprint 14-15: wizard interactivo + monorepo detect (9 tools soportadas).",
      "files": [
        "scripts/xdd-wizard.sh",
        "scripts/xdd-monorepo.sh"
      ]
    },
    "observability": {
      "description": "Sprint 18-19: OTel spans + session replay + cost tracker + context budget.",
      "files": [
        "scripts/xdd-otel.py",
        "scripts/xdd-replay.py",
        "scripts/xdd-cost.py",
        "scripts/xdd-context.py"
      ]
    },
    "governance-runtime": {
      "description": "Sprint 21: intent taxonomy + OAP authz <100ms.",
      "files": [
        "scripts/xdd-intent.py",
        "scripts/xdd-authz.py"
      ]
    },
    "ahe-evolve": {
      "description": "Sprint 22 + ADR-0029: AHE-style /evolve 3-layer obs + frozen transfer + trace summarize.",
      "files": [
        "scripts/xdd-trace-summarize.py",
        "scripts/xdd-frozen-transfer.py",
        "scripts/xdd-meta-eval.py"
      ]
    },
    "protocols": {
      "description": "Sprint 23: A2A + AG-UI streaming spec.",
      "files": [
        "scripts/xdd-a2a.py",
        "scripts/xdd-agui.py"
      ]
    },
    "router": {
      "description": "Sprint 17 + ADR-0019: multi-provider LLM router (5 task \u00d7 4 providers).",
      "files": [
        "scripts/xdd-router.py"
      ]
    },
    "pentest": {
      "description": "Sprint 12 + ADR-0010: wrapper h\u00edbrido Shannon (AGPL opt-in).",
      "files": [
        "scripts/xdd-pentest.sh"
      ]
    }
  }
}
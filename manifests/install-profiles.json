{
  "$schema": "../schemas/install-profiles.schema.json",
  "version": "0.1.0",
  "description": "Perfiles de instalación X-DD. Cada perfil agrupa módulos coherentes para un caso de uso.",
  "profiles": {
    "minimal": {
      "description": "Mínima viable: solo núcleo + workflows + memoria. Sin agentes, sin hooks, sin MCP.",
      "modules": [
        "core",
        "workflows-core",
        "memory",
        "docs-governance"
      ]
    },
    "core": {
      "description": "Recomendada para empezar: núcleo + workflows + agentes + gate + memoria + CI.",
      "modules": [
        "core",
        "workflows-core",
        "agents-core",
        "gate-keeper",
        "memory",
        "ci-runtime",
        "docs-governance",
        "personas",
        "skills-core",
        "mcp-server-global"
      ]
    },
    "developer": {
      "description": "Perfil completo de desarrollo: incluye hooks runtime + MCP server.",
      "modules": [
        "core",
        "workflows-core",
        "agents-core",
        "gate-keeper",
        "hooks-runtime",
        "mcp-server",
        "platform-configs",
        "memory",
        "ci-runtime",
        "docs-governance",
        "personas",
        "skills-core",
        "mcp-server-global",
        "workspace-monorepo",
        "observability",
        "governance-runtime",
        "router"
      ]
    },
    "security": {
      "description": "Énfasis en SecDD: núcleo + hooks strict + AgentShield + gate firmado.",
      "modules": [
        "core",
        "workflows-core",
        "agents-core",
        "gate-keeper",
        "hooks-runtime",
        "agent-shield",
        "memory",
        "ci-runtime",
        "docs-governance",
        "personas",
        "skills-core",
        "mcp-server-global",
        "governance-runtime",
        "pentest"
      ]
    },
    "research": {
      "description": "Investigación: núcleo + eval-harness + continuous learning + memoria.",
      "modules": [
        "core",
        "workflows-core",
        "agents-core",
        "gate-keeper",
        "eval-harness",
        "continuous-learning",
        "memory",
        "docs-governance",
        "personas",
        "skills-core",
        "mcp-server-global",
        "observability",
        "ahe-evolve"
      ]
    },
    "full": {
      "description": "Todo (incluyendo capacidades de v0.1.0 sprint 9-12 cuando estén disponibles).",
      "modules": [
        "core",
        "workflows-core",
        "agents-core",
        "gate-keeper",
        "hooks-runtime",
        "mcp-server",
        "platform-configs",
        "memory",
        "ci-runtime",
        "eval-harness",
        "continuous-learning",
        "orchestration",
        "agent-shield",
        "docs-governance",
        "personas",
        "skills-core",
        "mcp-server-global",
        "workspace-monorepo",
        "observability",
        "governance-runtime",
        "ahe-evolve",
        "protocols",
        "router",
        "pentest"
      ]
    },
    "lean": {
      "description": "Sprint 32: Wrapper-global only. <5MB. NO copia framework local (prompts/scripts/skills/templates). Requiere `bash xdd-mcp-install-global.sh` ejecutado. Agentes/skills/scripts vía MCP + PATH global.",
      "modules": [
        "core-essential",
        "workflows-essential",
        "memory",
        "platform-configs",
        "gate-keeper"
      ],
      "requires_wrapper_global": true,
      "max_size_mb": 5
    }
  }
}
# EditorConfig — X-DD
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.{py,sh,bash}]
indent_size = 4

[Makefile]
indent_style = tab

[*.{yml,yaml,json}]
indent_size = 2

[*.{tsv}]
indent_style = tab
